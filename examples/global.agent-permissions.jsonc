    "ask": [
      {
        "tool": "Bash",
        "command": [
          "sed",
          "gsed"
        ],
        "when": {
          "hasOption": [
            "-i",
            "--in-place"
          ]
        },
        "reason": "sed in-place editing changes files"
      }
    ],
